# ==============================================================================
# NOTEFLOW ENVIRONMENT VARIABLES & CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to:
#   - apps/api/.env         (for backend local development)
#   - apps/web/.env.local   (for frontend local development)
# And set these variables in your Vercel/Railway Production settings dashboards.
# ==============================================================================

# ==============================================================================
# 1. DATABASE CONFIGURATION (Backend Only - apps/api/.env)
# ==============================================================================
# Neon / Managed PostgreSQL is highly recommended. 
# For Vercel serverless, ALWAYS use the pooled connection string for DATABASE_URL 
# to avoid connection exhaustion, and direct string for DIRECT_URL (for migrations).

# POOLED DATABASE URL (Used by application for queries)
# Format: postgresql://[user]:[password]@[host]-pooler.[region].aws.neon.tech/[dbname]?sslmode=require&pgbouncer=true&connect_timeout=3&connection_limit=1
DATABASE_URL="postgresql://user:password@ep-cool-pooler-123456.us-east-2.aws.neon.tech/noteflow?sslmode=require&pgbouncer=true&connect_timeout=3&connection_limit=1"

# DIRECT DATABASE URL (Used for Prisma migrations only)
# Format: postgresql://[user]:[password]@[host].[region].aws.neon.tech/[dbname]?sslmode=require
DIRECT_URL="postgresql://user:password@ep-cool-123456.us-east-2.aws.neon.tech/noteflow?sslmode=require"

# Prisma connection details
PRISMA_CONNECT_TIMEOUT_MS=3000

# ==============================================================================
# 2. JWT SECURITY & AUTHENTICATION (Backend Only)
# ==============================================================================
# Generate a strong 32+ character random string in terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="generate-a-strong-unique-random-hex-string-for-production"
JWT_EXPIRATION="7d"

# ==============================================================================
# 3. TIMEOUT & RESILIENCE CONFIGURATIONS (Backend Only)
# ==============================================================================
# Prevents backend calls from hanging in serverless environment
REQUEST_TIMEOUT_MS=15000

# ==============================================================================
# 4. FRONTEND CONFIGURATION (Frontend Only - apps/web/.env.local)
# ==============================================================================
# URL of your NestJS backend API.
# Local development: http://localhost:3001
# Production: Set to your backend Vercel deployment URL (e.g., https://api.yourdomain.app)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ==============================================================================
# 5. BACKEND CORS & PORT CONFIGURATION (Backend Only)
# ==============================================================================
# Comma-separated list of allowed origins.
# MUST include your production frontend Vercel URL in production.
CORS_ORIGIN="http://localhost:3000,http://localhost:5173,https://ai-note-app-taupe.vercel.app,https://web-beta-rouge-77.vercel.app"

# Local port
PORT=3001

# Node Environment ('development' or 'production')
NODE_ENV="development"

# ==============================================================================
# 6. AI INTEGRATION CONFIGURATION (Backend Only)
# ==============================================================================
# Key from OpenRouter (https://openrouter.ai/keys)
# If empty, the backend automatically activates a fallback local summary generator.
OPENROUTER_API_KEY="sk-or-v1-your-openrouter-key-here"
OPENROUTER_MODEL="openrouter/auto"

# ==============================================================================
# 7. REDIS CONFIGURATION (Backend Only - Optional)
# ==============================================================================
# Redis connection URL for background queues and caching.
REDIS_URL="redis://localhost:6379"

# ==============================================================================
# PRODUCTION DEPLOYMENT & SECURITY GUIDELINES
# ==============================================================================
# 1. CORS_ORIGIN: Ensure this exactly matches your production frontend URL.
# 2. SSL Mode: Ensure `sslmode=require` is present in your PostgreSQL URLs.
# 3. Connection Pooling: Set `pgbouncer=true` and `connection_limit=1` on Vercel 
#    to prevent exhausting Neon connections.
# 4. Never commit actual .env files to repository source control.
# ==============================================================================
