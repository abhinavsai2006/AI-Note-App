# Example environment variables for local development and deployment
# Copy this file to apps/api/.env and apps/web/.env.local and fill values

# Database (Postgres)
DATABASE_URL="postgres://user:password@host:5432/dbname?schema=public"
# JWT secret for signing tokens
JWT_SECRET="replace-with-a-secure-random-string"

# Public frontend URL (used to build share links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3333"

# OpenRouter / OpenAI API key for AI features
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="openai/gpt-5.2"

# Optional: Redis URL for BullMQ
REDIS_URL="redis://localhost:6379"
