# ============================================
# NOTEFLOW ENVIRONMENT VARIABLES
# ============================================
# Copy to apps/api/.env (backend)
# Copy to apps/web/.env.local (frontend)
# ============================================

# ============================================
# DATABASE (Backend Only - apps/api/.env)
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/noteflow?schema=public"

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate secure key: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters"
JWT_EXPIRATION="7d"

# ============================================
# FRONTEND URLs (Frontend Only - apps/web/.env.local)
# ============================================
# Local development (optional, defaults to /api)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Production (set this on Vercel)
# NEXT_PUBLIC_API_URL="https://api.yourdomain.com"

# ============================================
# BACKEND URLS (Backend Only - apps/api/.env)
# ============================================
# CORS Origins (allow your frontend domain)
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Port for API server
PORT=3001

# Environment
NODE_ENV="development"

# ============================================
# AI INTEGRATION (OpenRouter or OpenAI)
# ============================================
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-your-api-key-here"
OPENROUTER_MODEL="openrouter/auto"

# Alternative: Use OpenAI directly
# OPENAI_API_KEY="sk-your-openai-key"
# OPENAI_MODEL="gpt-4"

# ============================================
# REDIS (Optional - for caching & queues)
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================
# 1. Set strong JWT_SECRET (32+ characters)
# 2. Use managed PostgreSQL (Neon, Supabase, Railway)
# 3. Update CORS_ORIGIN to production frontend
# 4. Set NODE_ENV=production
# 5. Use Vercel/Railway secret management
# 6. Never commit .env files
# 7. Rotate secrets periodically
